<Project>
  <!--
    Prevent R3EventsGenerator.Attributes.dll from being copied to the user's
    output directory.

    R3Events.props supplies the compile-time reference for NuGet installs where
    Visual Studio omits "compile" from IncludeAssets. This target still matters
    for package/project-reference restore paths where the attributes assembly
    can otherwise flow into CopyLocal.
  -->
  <Target Name="ExcludeR3EventsAttributesFromCopyLocal"
          AfterTargets="ResolveLockFileCopyLocalFiles">
    <ItemGroup>
      <ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)"
        Condition="'%(Filename)' == 'R3EventsGenerator.Attributes'" />
    </ItemGroup>
  </Target>
</Project>
